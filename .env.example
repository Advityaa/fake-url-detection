# Copy this file to ".env" and adjust values as needed.
#
# This template ships the LIVE-DEMO defaults: three optional stages are ON
# (Playwright rendering, dynamic-cloaking analysis, wording-only LLM explanation).
# Each degrades gracefully (no Chromium -> requests crawler; no API key / failed
# call -> deterministic explainer), so the pipeline always runs end-to-end.

# LLM-based explanation. ON by default here. WORDING ONLY — the classification and
# risk score always come from the deterministic rule engine and are NEVER
# overridden by the LLM. With no API key set, it silently uses the deterministic
# explainer. For Gemini no SDK is needed (uses httpx); anthropic/openai need their SDK.
USE_LLM=true

# Which provider to use when USE_LLM=true. Supported: "gemini", "anthropic" or "openai".
LLM_PROVIDER=gemini

# API keys (DO NOT commit your real .env). Leave blank to force fallback mode.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Gemini (Google Generative Language API). GOOGLE_API_KEY also works as an alias.
# Also read directly by the evaluation raw-LLM baseline (evaluation/llm_baseline.py)
# to answer "why not just ask an LLM?"; if blank, that baseline is skipped cleanly.
GEMINI_API_KEY=

# Model overrides.
ANTHROPIC_MODEL=claude-opus-4-8
OPENAI_MODEL=gpt-4o-mini
# Gemini model id (see https://ai.google.dev/gemini-api/docs/models). A fast,
# low-cost model is recommended for the naive baseline, e.g. gemini-flash-latest.
GEMINI_MODEL=gemini-flash-latest

# LLM call safety limits (used only when the LLM path is active).
LLM_TIMEOUT_SECONDS=20
LLM_MAX_TOKENS=400

# Crawler safety settings.
CRAWLER_TIMEOUT_SECONDS=10
CRAWLER_MAX_REDIRECTS=5
CRAWLER_USER_AGENT=phishing-rag-mvp-research-bot/0.1 (defensive-research; +local-prototype)

# Live-fetch backend: "playwright" (default here; headless Chromium rendering for
# JS-built pages) or "requests" (bounded GET via httpx). The playwright backend
# needs `pip install playwright` + `playwright install chromium`; if unavailable
# it falls back to the requests crawler automatically. It also gates the
# dynamic-cloaking analysis stage below.
RENDER_BACKEND=playwright
RENDER_TIMEOUT_SECONDS=8

# Dynamic-cloaking analysis runs automatically when RENDER_BACKEND=playwright:
# it renders the page, scrolls/waits, and diffs the DOM to catch credential
# fields injected only after interaction. SAFE mode — scroll/wait/diff only.
DYNAMIC_ANALYSIS_TIMEOUT_SECONDS=12
# Keep clicking OFF: no buttons are clicked (scroll/wait/diff only). Setting this
# true would additionally click a tightly-matched login/sign-in control.
CLICK_LOGIN_BUTTON=false

# Retriever backend for the local RAG knowledge base.
#   "tfidf"     -> scikit-learn TF-IDF (default; zero heavy dependencies)
#   "embedding" -> local sentence-transformer + Chroma vector DB
# The embedding backend needs `pip install sentence-transformers chromadb`; if
# those (or the model) are unavailable, the system falls back to tfidf automatically.
RETRIEVER_BACKEND=tfidf
# Sentence-transformer model used when RETRIEVER_BACKEND=embedding (downloaded
# once to the local HF cache on first build; never fetched at query time).
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Threat-intelligence settings.
# Set to "false" to disable external threat-feed lookups entirely.
THREAT_INTEL_ENABLED=true
# OpenPhish public phishing feed (downloaded and cached locally).
OPENPHISH_FEED_URL=https://openphish.com/feed.txt
# How long (seconds) to reuse the cached feed before refreshing (default 6 hours).
THREAT_CACHE_TTL_SECONDS=21600
# Optional PhishTank API key. If blank, PhishTank is skipped and only the
# cached OpenPhish feed is used. (PhishTank registration may be closed.)
PHISHTANK_API_KEY=
PHISHTANK_CHECK_URL=https://checkurl.phishtank.com/checkurl/

# Optional multimodal stage: render a screenshot and OCR its text to catch
# image-only brand impersonation and visible-vs-DOM text cloaking.
# OFF by default. Requires: `pip install playwright pytesseract Pillow`,
# `playwright install chromium`, and the Tesseract OCR binary on the system.
# If any of those are missing the stage is skipped (no crash).
USE_MULTIMODAL=false
MULTIMODAL_TIMEOUT_SECONDS=15
# Optional explicit path to the Tesseract binary if it is not on PATH
# (e.g. a conda-forge install: ~/miniconda3/bin/tesseract). Blank = use PATH.
TESSERACT_CMD=

# Domain-reputation settings (WHOIS age / DNS records / TLS certificate).
# Set to "false" to disable these lookups entirely.
DOMAIN_INTEL_ENABLED=true
# Per-lookup timeout in seconds (WHOIS/DNS/TLS each; lookups never block longer).
DOMAIN_INTEL_TIMEOUT_SECONDS=5
# A domain younger than this many days is treated as "newly registered" (risk).
NEW_DOMAIN_AGE_DAYS=30
# Optional: local MaxMind GeoLite2 DB for the LOW-confidence ASN/geo conflict
# signal. Leave blank to skip geo lookups entirely (recommended default).
GEOIP_DB_PATH=
