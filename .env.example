# Copy this file to ".env" and adjust values as needed.
# By default the project runs fully offline with a deterministic fallback explainer.

# Set to "true" to enable an LLM-based explanation (requires a provider + API key).
USE_LLM=false

# Which provider to use when USE_LLM=true. Supported placeholders: "anthropic" or "openai".
LLM_PROVIDER=anthropic

# API keys (DO NOT commit your real .env). Leave blank to force fallback mode.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional model overrides (placeholders for future phases).
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
OPENAI_MODEL=gpt-4o-mini

# Crawler safety settings.
CRAWLER_TIMEOUT_SECONDS=10
CRAWLER_MAX_REDIRECTS=5
CRAWLER_USER_AGENT=phishing-rag-mvp-research-bot/0.1 (defensive-research; +local-prototype)
